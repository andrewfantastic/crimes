{
  "name": "crimes",
  "version": "0.0.0",
  "description": "A crime scene investigator for your codebase. Built for agents, readable by humans.",
  "license": "MIT",
  "author": "Andrew Mayfield",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "crimes": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "prepack": "node ./scripts/prepack.mjs",
    "postpack": "node ./scripts/postpack.mjs"
  },
  "devDependencies": {
    "@crimes/core": "workspace:*",
    "@crimes/reporter": "workspace:*",
    "@types/node": "^22.0.0",
    "commander": "^12.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
