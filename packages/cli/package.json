{
  "name": "crimes",
  "version": "0.0.0",
  "description": "A crime scene investigator for your codebase. Built for agents, readable by humans.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "crimes": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@crimes/core": "workspace:*",
    "@crimes/reporter": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
