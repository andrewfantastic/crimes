{
  "name": "crimes",
  "version": "0.9.0",
  "description": "A crime scene investigator for your codebase. Built for agents, readable by humans.",
  "license": "MIT",
  "author": "Andrew Mayfield",
  "homepage": "https://crimes.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewfantastic/crimes.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/andrewfantastic/crimes/issues"
  },
  "keywords": [
    "cli",
    "code-quality",
    "agent",
    "ai",
    "static-analysis",
    "code-smells",
    "typescript",
    "javascript",
    "maintainability",
    "code-review"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "crimes": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "scripts/postinstall.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "smoke": "node ./scripts/smoke.mjs",
    "prepack": "node ./scripts/prepack.mjs",
    "postinstall": "node ./scripts/postinstall.mjs",
    "postpack": "node ./scripts/postpack.mjs"
  },
  "dependencies": {
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@crimes/core": "workspace:*",
    "@crimes/reporter": "workspace:*",
    "@types/node": "^22.0.0",
    "commander": "^12.1.0",
    "tsup": "^8.3.5",
    "vitest": "^2.1.5"
  }
}
