# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
out/
.turbo/

# Type-check incremental output
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor
.vscode/
.idea/
.DS_Store

# Test coverage
coverage/

# Env
.env
.env.local
.env.*.local

# crimes state
# `.crimes/baseline.json` is intended to be committed — it pins the set of
# pre-existing findings that `crimes baseline check` ignores. Only regenerable
# cache state belongs here.
.crimes/cache/

# npm pack output
*.tgz

# Eval-harness OSS-fixture bodies. The `.crimes-eval-meta.json` per
# fixture IS committed; the cloned upstream body is gitignored so we
# never ship third-party source in this repo. `pnpm run evals:setup`
# materialises the body fresh at the pinned SHA.
evals/fixtures/0[2-4]-*/**
!evals/fixtures/0[2-4]-*/.crimes-eval-meta.json
# Eval replay output (per PR run, not pinned). The pinned per-version
# results under evals/results/<version>/ are committed.
evals/replay/
evals/diff-summary.md
