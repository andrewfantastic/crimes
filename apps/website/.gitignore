# Generated by scripts/sync-docs.mjs from <repo>/docs/**.
# Source of truth is the repo's docs/ tree; this directory is a
# build-time copy for Astro / Starlight to consume.
src/content/docs/

# Astro caches
.astro/

# Build output already covered by the root .gitignore; listed here
# explicitly so the website is greppable in isolation.
dist/

# Public assets are populated by sync-docs (copying the landing
# favicon into Astro's public dir). The source lives in landing/.
public/
