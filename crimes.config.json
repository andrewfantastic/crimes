{
  "$schema": "https://crimes.sh/schema/0.1.0/config.json",
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/out/**",
    "**/coverage/**",
    "**/*.min.js",
    "**/*.generated.*",
    "**/.crimes/**",
    "evals/fixtures/**",
    "examples/messy-ts-app/**"
  ],
  "assets": {
    "exclude": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/.next/**",
      "**/out/**",
      "**/coverage/**",
      "**/.crimes/**",
      "**/public/vendor/**",
      "**/__snapshots__/**",
      "**/fixtures/**",
      "**/*.test.{png,jpg,jpeg,gif,webp,avif,svg}",
      "evals/fixtures/**",
      "examples/messy-ts-app/**"
    ]
  }
}
